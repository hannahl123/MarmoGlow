{
  "manifest_version": 3,
  "name": "MarmoGlow",
  "version": "1.0",
  "description": "A UI extension to transform Marmoset into a clean, modern, and actually-usable interface.",
  "content_scripts": [
    {
      "matches": ["https://marmoset.student.cs.uwaterloo.ca/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "permissions": ["storage"],
  "applications": {
    "gecko": {
      "id": "marmoglow@uwaterloo.ca",
      "strict_min_version": "102.0"
    }
  }
}
